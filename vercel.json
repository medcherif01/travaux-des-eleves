{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/students.ts": { "maxDuration": 30 },
    "api/analyze-handwriting.ts": { "maxDuration": 60 },
    "api/detect-questions.ts": { "maxDuration": 60 },
    "api/generate-answers.ts": { "maxDuration": 60 },
    "api/generate-comments.ts": { "maxDuration": 60 }
  }
}
